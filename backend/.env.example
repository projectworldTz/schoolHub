APP_NAME="SchoolHub Africa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=schoolhub_africa
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=schoolhub_cache

MEMCACHED_HOST=127.0.0.1

# Not used locally (see above — cache/queue/session run on the database
# driver instead). Left configured for when Redis becomes available
# (Docker, Memurai, or a Linux host) — production should use redis for all
# three.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# No local mail catcher installed — mail is logged to storage/logs/laravel.log.
# Switch to smtp (e.g. Mailpit on 127.0.0.1:1025) if you want to see rendered emails.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@schoolhub.africa"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# AI Assistant (lesson plans, in-app chat) — leave blank to keep the
# feature disabled; AiAssistantService::isConfigured() checks this and the
# frontend shows a "not configured" state instead of erroring. Get a key
# from https://console.anthropic.com/.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

VITE_APP_NAME="${APP_NAME}"
